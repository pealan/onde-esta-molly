# Copy this file to terraform.tfvars and fill in the two required values.
# terraform.tfvars itself is .gitignored.

# Your laptop's public SSH key, single line.
# Get it: cat ~/.ssh/id_ed25519.pub
admin_public_key = "ssh-ed25519 AAAA... pealan@gente-admin"

# Your laptop's public IP, as a /32 CIDR.
# Get it: echo "$(curl -s ifconfig.me)/32"
# Update this whenever your IP changes (e.g. new ISP, traveling).
admin_ip_cidr = "203.0.113.42/32"

# Optional overrides — defaults are already in variables.tf.
# region    = "sa-east-1"
# subdomain = "molly"
# domain    = "pealan.dev"
